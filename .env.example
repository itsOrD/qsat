# Slack (set ONE of these)
# Local dev (without Docker):
SLACK_WEBHOOK_BASE_URL=http://localhost:9000/slack/webhook
# Docker Compose (use service name instead of localhost):
# SLACK_WEBHOOK_BASE_URL=http://mock-slack:9000/slack/webhook
# Real Slack (single webhook mode):
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Storage
DATABASE_PATH=./data/alerts.db
APP_MODE=demo
# For secured deployments:
# APP_MODE=secure
# RBAC_RUNNER_TOKENS=runner-token-1,runner-token-2
# RBAC_VIEWER_TOKENS=viewer-token-1
# Optional explicit override (normally inferred from APP_MODE):
# RBAC_ENABLED=true

# Business Logic
ARR_THRESHOLD=10000
APP_BASE_URL=https://app.yourcompany.com

# GCS (only needed for gs:// URIs)
# GOOGLE_APPLICATION_CREDENTIALS=./config/sa-key.json

# Email (optional — defaults to logging backend)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=alerts@yourcompany.com
